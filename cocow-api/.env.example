DATABASE_URL="postgresql://cocow_user:cocow_pass@localhost:5432/cocow"
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# SSO / OAuth 2 + OIDC
SSO_URL=http://localhost:8848
SSO_CLIENT_ID=your_client_id
SSO_CLIENT_SECRET=your_client_secret
SSO_REDIRECT_URI=http://localhost:3001/api/v1/login/callback

# cocow-api 服务账号：用于 cocow-api 以自己的身份登录 SSO 服务器
# createSsoSession() 会自动维护 JSESSIONID，对 SSO 内部 API 的调用均携带此账号的 Cookie
SSO_SERVICE_USERNAME=your_service_account
SSO_SERVICE_PASSWORD=your_service_password